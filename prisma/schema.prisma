generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int      @id @default(autoincrement())
  displayName           String   @map("display_name")
  displayNameNormalized String   @unique @map("display_name_normalized")
  passwordHash          String   @map("password_hash")
  isAdmin               Boolean  @default(false) @map("is_admin")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdInvites        Invite[] @relation("CreatedInvites")
  claimedInvites        Invite[] @relation("ClaimedInvites")
  createdTokens         MachineToken[] @relation("CreatedTokens")
  playHistory           PlayHistory[] @relation("PlayHistory")
  queueEntries          QueueEntry[]

  @@map("users")
}

model Invite {
  id          String   @id
  createdBy   Int      @map("created_by")
  creator     User     @relation("CreatedInvites", fields: [createdBy], references: [id], onDelete: Cascade)
  claimedBy   Int?     @map("claimed_by")
  claimer     User?    @relation("ClaimedInvites", fields: [claimedBy], references: [id], onDelete: Cascade)
  roleIsAdmin Boolean  @default(false) @map("role_is_admin")
  expiresAt   DateTime @map("expires_at") @db.Timestamptz(6)
  claimedAt   DateTime? @map("claimed_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("invites")
}

model MachineToken {
  id        Int       @id @default(autoincrement())
  name      String
  token     String    @unique
  createdBy Int       @map("created_by")
  creator   User      @relation("CreatedTokens", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeen  DateTime? @map("last_seen") @db.Timestamptz(6)

  @@map("machine_tokens")
}

model Setting {
  key       String   @id
  value     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("settings")
}

model Pack {
  id              Int      @id @default(autoincrement())
  folderName      String   @unique @map("folder_name")
  sortIndex       String?  @map("sort_index")
  titles          String
  platforms       String?
  regions         String?
  earliestRelease String?  @map("earliest_release")
  source          String?
  isCustom        Boolean  @default(false) @map("is_custom")
  isCommunity     Boolean  @default(false) @map("is_community")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  songs           Song[]

  @@map("packs")
}

model Song {
  id             Int           @id @default(autoincrement())
  packId         Int           @map("pack_id")
  pack           Pack          @relation(fields: [packId], references: [id], onDelete: Cascade)
  title          String
  titleTranslit  String?       @map("title_translit")
  artist         String?
  artistTranslit String?       @map("artist_translit")
  genre          String?
  credit         String?
  displayBpm     String?       @map("display_bpm")
  bpmMin         Float?        @map("bpm_min")
  bpmMax         Float?        @map("bpm_max")
  offset         Float?
  sampleStart    Float?        @map("sample_start")
  sampleLength   Float?        @map("sample_length")
  filePath       String        @unique @map("file_path")
  simfileType    String        @map("simfile_type")
  checksum       String
  available      Boolean       @default(true)
  ingestFlags    String?       @map("ingest_flags")
  lastScanned    DateTime?     @map("last_scanned") @db.Timestamptz(6)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  charts         Chart[]
  playHistory    PlayHistory[]
  queueEntries   QueueEntry[]

  @@map("songs")
}

model Chart {
  id             Int      @id @default(autoincrement())
  songId         Int      @map("song_id")
  song           Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  gameMode       String   @map("game_mode")
  difficultySlot String   @map("difficulty_slot")
  meter          Int
  author         String?
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  queueEntries   QueueEntry[]
  playHistory    PlayHistory[]

  @@unique([songId, gameMode, difficultySlot])
  @@map("charts")
}

model PlayHistory {
  id       Int      @id @default(autoincrement())
  songId   Int      @map("song_id")
  song     Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  chartId  Int      @map("chart_id")
  chart    Chart    @relation(fields: [chartId], references: [id], onDelete: Cascade)
  userId   Int      @map("user_id")
  user     User     @relation("PlayHistory", fields: [userId], references: [id], onDelete: Cascade)
  score    Decimal? @db.Decimal(5, 2)
  grade    String?
  isTest   Boolean  @default(false) @map("is_test")
  playedAt DateTime @default(now()) @map("played_at") @db.Timestamptz(6)

  @@map("play_history")
}

model QueueEntry {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  songId    Int      @map("song_id")
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  chartId   Int      @map("chart_id")
  chart     Chart    @relation(fields: [chartId], references: [id], onDelete: Cascade)
  status    String   @default("queued")
  playOrder Int      @map("play_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, playOrder])
  @@index([userId, status, createdAt])
  @@map("queue_entries")
}
