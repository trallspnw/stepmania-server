generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int      @id @default(autoincrement())
  displayName           String   @map("display_name")
  displayNameNormalized String   @unique @map("display_name_normalized")
  passwordHash          String   @map("password_hash")
  isAdmin               Boolean  @default(false) @map("is_admin")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdInvites        Invite[] @relation("CreatedInvites")
  claimedInvites        Invite[] @relation("ClaimedInvites")

  @@map("users")
}

model Invite {
  id          String   @id
  createdBy   Int      @map("created_by")
  creator     User     @relation("CreatedInvites", fields: [createdBy], references: [id])
  claimedBy   Int?     @map("claimed_by")
  claimer     User?    @relation("ClaimedInvites", fields: [claimedBy], references: [id])
  roleIsAdmin Boolean  @default(false) @map("role_is_admin")
  expiresAt   DateTime @map("expires_at") @db.Timestamptz(6)
  claimedAt   DateTime? @map("claimed_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("invites")
}
